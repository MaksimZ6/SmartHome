@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    /* ТВОИ ТЕКУЩИЕ СТИЛИ */
    .top-row {
        display: none !important;
        visibility: hidden !important;
        border: none !important;
        height: 0 !important;
        min-height: 0 !important;
    }

    main { border: none !important; }

    .content {
        border-top: none !important;
        padding-top: 2rem !important;
    }

    .page { border: none !important; }

    .sidebar {
        border-top: none !important;
        background: rgba(13, 27, 42, 0.4) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px);
        border-right: 1px solid rgba(255, 255, 255, 0.1);
    }

    .navbar-toggler {
        display: none !important;
        opacity: 0 !important;
    }

    .nav-scrollable { padding-top: 1.5rem !important; }
    .nav-item:first-child { margin-top: 1rem !important; }

    /* --- ИСПРАВЛЕНИЕ БЕЛЫХ СПИСКОВ (SELECT) --- */
    
    /* Применяем ко всем выпадающим спискам в проекте */
    select, .form-select {
        background-color: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        border-radius: 8px !important;
        padding: 8px 12px !important;
        appearance: none !important; /* Убираем стандартный вид */
        -webkit-appearance: none;
        -moz-appearance: none;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='white' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: right 0.75rem center !important;
        background-size: 16px 12px !important;
    }

   
</style>